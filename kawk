#!/bin/sh
# kawk -- run a .kk program through the kawk interpreter.
#   ./kawk prog.kk [data ...]          run prog.kk on data files (or stdin)
#   ./kawk -F, prog.kk [data ...]      set the field separator
#   ./kawk -d prog.kk [data ...]       also dump the (retired) AWK to stderr
#   ./kawk -h [SYM]                    glyph reference (one glyph if SYM given)
#   ./kawk --explain 'PROG'            show how the program grouped (right-to-left)
#
# Trailing args that are real files are read as input; anything else is treated
# as literal input lines, so `./kawk sum.kk 5` works without a here-string.

here=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

case "$1" in
    -h|--help|help) exec python3 "$here/kawk.py" -h "$2" ;;
    --explain)      shift; exec python3 "$here/kawk.py" --explain "$@" ;;
esac

debug=0; fsopt=""
while :; do
    case "$1" in
        -d)  debug=1; shift ;;
        -F)  fsopt="-F $2"; shift 2 ;;
        -F*) fsopt="-F ${1#-F}"; shift ;;
        *)   break ;;
    esac
done

[ -n "$1" ] || { echo "usage: kawk [-d] [-F sep] prog[.kk] [data ...]" >&2; exit 2; }
prog=$1; shift

if   [ -f "$prog" ];    then :
elif [ -f "$prog.kk" ]; then prog="$prog.kk"
else echo "kawk: no such program: $prog (looked for '$prog' and '$prog.kk')" >&2; exit 1
fi

[ "$debug" = 1 ] && {
    awk=$(python3 "$here/kawk.py" --emit-awk "$prog" 2>&1)
    printf '%s\n' '--- would-be awk (retired backend) ---' "$awk" '--------------------------------------' >&2
}

if [ "$#" -gt 0 ] && [ ! -f "$1" ]; then
    printf '%s\n' "$@" | python3 "$here/kawk.py" $fsopt "$prog"
else
    cat -- "$@" | python3 "$here/kawk.py" $fsopt "$prog"
fi
